# =====================================================================
# bidbrainai-api — LOCAL DEV env (read by both `api` and `migrations`)
# =====================================================================
# All secrets below were randomly generated for THIS machine's local
# stack only. They are not production values. Do not commit to a repo
# that ships anywhere.

# --- Core ------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO

# In-Docker hostname `db` (compose service name), not localhost.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/postgres

# Browser runs the portal on localhost:3000 and calls the api cross-origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Required secrets (locally generated placeholders) ---------------
SUPABASE_JWT_SECRET=0c6b3b56b3d0eb11dee031ef9a14d71e0dff2df8269ce0d1bfefeca78614528b
BIDBRAINAI_API_INTERNAL_KEY=15665a6904789078dbb235ffe0dd25410315c66f3544e6af45b1728d6b2957b7
LLM_GATEWAY_INTERNAL_KEY=b855d371c51a426acb9a96218ced058343487de6a08f1a5ddcec2c958e92f4cb
LLM_CONFIG_ENCRYPTION_KEY=PfMCoOoDxJVYcOtb_MLLDnq1FE0Tu0kR_Xl_1-cKi_Q=
SCRAPER_API_KEY=d97897d1ddd198cdc8c1d25f19d05283

# --- Supabase (NOT running in the core stack — dummies so the app boots).
# Storage/auth features that hit these will fail gracefully at call time.
# If you later add the self-hosted Supabase stack, point these at Kong.
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_INTERNAL_URL=http://supabase-kong:8000
SUPABASE_SERVICE_KEY=local-dev-not-configured
SUPABASE_ANON_KEY=local-dev-not-configured
